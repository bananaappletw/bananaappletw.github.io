---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('treasure')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Treasure">
  <h1>Treasure</h1>
  <p style="color: #8b949e; margin-bottom: 2rem;">Curated thoughts and insights</p>
  <div style="margin-top: 2rem;">
    {posts.map(post => (
      <article style="margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #30363d;">
        <h2 style="margin-bottom: 0.5rem;">
          <a href={`/treasure/${post.slug}`}>{post.data.title}</a>
        </h2>
        <p style="color: #8b949e; margin-bottom: 0.5rem;">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        {post.data.tags && post.data.tags.length > 0 && (
          <div>
            {post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</BaseLayout>
