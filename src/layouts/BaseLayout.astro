---
interface Props {
  title?: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title ? `${title} | bananaappletw` : "bananaappletw's blog"}</title>
  <style is:global>
    :root {
      color-scheme: dark;
      --bg: #0d1117;
      --fg: #c9d1d9;
      --border: #30363d;
      --accent: #58a6ff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
    }

    body {
      background: var(--bg);
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    nav {
      background: #161b22;
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
      margin-bottom: 2rem;
    }

    nav > div {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav a {
      margin-right: 2rem;
      font-weight: 500;
    }

    nav a.active {
      color: #fff;
      border-bottom: 2px solid var(--accent);
      padding-bottom: 0.25rem;
    }

    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    footer {
      border-top: 1px solid var(--border);
      margin-top: 4rem;
      padding: 2rem 0;
      text-align: center;
      font-size: 0.9rem;
      color: #8b949e;
    }

    h1, h2, h3, h4, h5, h6 {
      margin: 1rem 0 0.5rem 0;
      line-height: 1.2;
    }

    h1 { font-size: 2rem; }
    h2 { font-size: 1.5rem; }
    h3 { font-size: 1.25rem; }

    p {
      margin-bottom: 1rem;
    }

    code {
      background: #161b22;
      padding: 0.2em 0.4em;
      border-radius: 3px;
      font-family: 'Monaco', 'Courier New', monospace;
      font-size: 0.9em;
    }

    pre {
      background: #0d1117;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1rem;
      overflow-x: auto;
      margin: 1rem 0;
    }

    pre code {
      background: none;
      padding: 0;
    }

    blockquote {
      border-left: 4px solid var(--accent);
      padding-left: 1rem;
      margin: 1rem 0;
      color: #8b949e;
    }

    .admonition {
      border-left: 4px solid #58a6ff;
      padding: 1rem;
      margin: 1rem 0;
      border-radius: 4px;
      background: rgba(88, 166, 255, 0.1);
    }

    .admonition-warning {
      border-left-color: #d29922;
      background: rgba(210, 153, 34, 0.1);
    }

    .admonition-caution {
      border-left-color: #f85149;
      background: rgba(248, 81, 73, 0.1);
    }

    .tag {
      display: inline-block;
      background: var(--border);
      padding: 0.25rem 0.75rem;
      border-radius: 12px;
      font-size: 0.85rem;
      margin-right: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .post-meta {
      color: #8b949e;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <nav>
    <div>
      <a href="/" style="font-size: 1.25rem; font-weight: 600; margin-right: auto;">🍌 bananaappletw</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>Blog</a>
      <a href="/archives" class={currentPath.startsWith('/archives') ? 'active' : ''}>Archives</a>
      <a href="/treasure" class={currentPath.startsWith('/treasure') ? 'active' : ''}>Treasure</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; 2024 bananaappletw. All rights reserved.</p>
  </footer>
</body>
</html>
